{
  "name": "@spaceparrots/nit",
  "version": "1.2.0",
  "description": "Point-and-click website annotation that hands small UI fixes to a coding agent.",
  "type": "module",
  "bin": {
    "nit": "./dist/cli/index.js"
  },
  "files": [
    "dist",
    "CHANGELOG.md",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "annotation",
    "website-review",
    "design-review",
    "feedback",
    "playwright",
    "coding-agent",
    "mcp",
    "qa",
    "ui"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/SpaceParrots/nit.git"
  },
  "bugs": {
    "url": "https://github.com/SpaceParrots/nit/issues"
  },
  "homepage": "https://github.com/SpaceParrots/nit#readme",
  "author": "Kevin Mattutat <kevin.mattutat@spaceparrots.de>",
  "scripts": {
    "build": "tsc -p tsconfig.json && node -e \"const f=require('node:fs');f.cpSync('src/overlay/overlay.css','dist/overlay/overlay.css');f.cpSync('src/panel/panel.css','dist/panel/panel.css')\"",
    "gen:logo": "node scripts/gen-logo.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "pretest": "npm run build",
    "test": "node --test",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "prepublishOnly": "npm run lint && npm run build"
  },
  "engines": {
    "node": ">=20.12"
  },
  "dependencies": {
    "@clack/prompts": "^1.7.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "commander": "^15.0.0",
    "esbuild": "^0.25.0",
    "fflate": "^0.8.3",
    "playwright": "^1.54.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@stylistic/eslint-plugin": "^5.10.0",
    "@types/node": "^24.0.0",
    "eslint": "^10.7.0",
    "globals": "^17.7.0",
    "typescript": "^7.0.2",
    "typescript-eslint": "^8.46.0"
  },
  "license": "AGPL-3.0-or-later",
  "publishConfig": {
    "access": "public"
  }
}
